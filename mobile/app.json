{
  "expo": {
    "name": "noAlone",
    "slug": "noalone",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1a1a2e"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.noalone.app",
      "infoPlist": {
        "NSCameraUsageDescription": "noAlone needs camera access for profile photos",
        "NSMicrophoneUsageDescription": "noAlone needs microphone access for voice rooms",
        "NSPhotoLibraryUsageDescription": "noAlone needs photo library access for sharing images"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.noalone.app",
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_EXTERNAL_STORAGE",
        "WRITE_EXTERNAL_STORAGE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "react-native-webview",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#7c3aed"
        }
      ],
      "expo-font"
    ],
    "scheme": "noalone",
    "newArchEnabled": true,
    "extra": {
      "eas": {
        "projectId": "10da4c07-393f-49ae-9569-cb174761be35"
      }
    },
    "owner": "anuragbhumca07"
  }
}
